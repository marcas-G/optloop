ARG OPTLOOP_BASE_IMAGE=node:20-bookworm-slim
FROM ${OPTLOOP_BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONPATH=/workspace:/workspace/src
ARG OPTLOOP_NPM_REGISTRY=""

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    git \
    python3 \
    python3-pip \
    procps \
    tini \
    && rm -rf /var/lib/apt/lists/*

# Compatibility alias for projects that invoke `python`.
RUN ln -sf /usr/bin/python3 /usr/local/bin/python

# Install Claude Code CLI globally.
RUN if [ -n "$OPTLOOP_NPM_REGISTRY" ]; then npm config set registry "$OPTLOOP_NPM_REGISTRY"; fi && \
    npm install -g @anthropic-ai/claude-code

RUN mkdir -p /home/node/.claude /tmp/optloop-home /workspace && \
    chown -R node:node /home/node /tmp/optloop-home /workspace

USER node
WORKDIR /workspace

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["bash", "-lc", "set -eu; mkdir -p /opt/optloop-home/.claude /tmp/optloop-home/.claude /home/node/.claude /workspace/.optloop/runtime/home/.claude; exec tail -f /dev/null"]
