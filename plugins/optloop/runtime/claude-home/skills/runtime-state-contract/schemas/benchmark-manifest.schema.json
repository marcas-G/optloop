{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OptLoopBenchmarkManifest",
  "type": "object",
  "required": [
    "version",
    "benchmark_command",
    "correctness_commands",
    "primary_metric",
    "metric_direction",
    "metric_unit",
    "warmup_runs",
    "measured_runs",
    "acceptance",
    "artifacts_dir"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "benchmark_command": {
      "type": "string"
    },
    "correctness_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "primary_metric": {
      "type": "string"
    },
    "metric_direction": {
      "type": "string",
      "enum": [
        "lower",
        "higher"
      ]
    },
    "metric_unit": {
      "type": "string"
    },
    "warmup_runs": {
      "type": "integer",
      "minimum": 0
    },
    "measured_runs": {
      "type": "integer",
      "minimum": 2
    },
    "acceptance": {
      "type": "object",
      "required": [
        "min_relative_improvement",
        "confidence"
      ],
      "properties": {
        "min_relative_improvement": {
          "type": "number",
          "minimum": 0
        },
        "confidence": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 0.999
        }
      }
    },
    "artifacts_dir": {
      "type": "string"
    }
  }
}
