#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OPTLOOP_BIN="$SELF_DIR/optloop"
OPTLOOP_INIT="$SELF_DIR/optloop-init"

cd "$REPO_ROOT"
mkdir -p .optloop/logs

PID_FILE=".optloop/runner.pid"
if [ -f "$PID_FILE" ]; then
  PID="$(tr -d '[:space:]' < "$PID_FILE" || true)"
  if [ -n "${PID:-}" ] && kill -0 "$PID" 2>/dev/null; then
    echo "optloop already running pid=$PID"
    exit 0
  fi
  rm -f "$PID_FILE"
fi

if [ ! -x "$OPTLOOP_BIN" ]; then
  chmod +x "$OPTLOOP_BIN" 2>/dev/null || true
fi
if [ -f "$OPTLOOP_INIT" ] && [ ! -x "$OPTLOOP_INIT" ]; then
  chmod +x "$OPTLOOP_INIT" 2>/dev/null || true
fi

if [ -f "$OPTLOOP_INIT" ]; then
  if ! bash "$OPTLOOP_INIT" > .optloop/logs/launcher-init.out 2>&1; then
    cat .optloop/logs/launcher-init.out >&2
    exit 1
  fi
fi

bash "$OPTLOOP_BIN" init >/dev/null 2>&1 || true

printf '[optloop-launch] new background run started at %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" > .optloop/logs/controller.out
nohup env PYTHONUNBUFFERED=1 bash "$OPTLOOP_BIN" start \
  >> .optloop/logs/controller.out 2>&1 < /dev/null &
PID=$!
echo "optloop launched pid=$PID"
exit 0
